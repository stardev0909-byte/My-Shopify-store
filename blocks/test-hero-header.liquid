<div class="test-header" data-test-header {{ block.shopify_attributes }}>
  <div class="test-header__bar">
    <button
      type="button"
      class="test-header__toggle"
      data-test-header-toggle
      aria-expanded="false"
      aria-controls="test-header-panel-{{ block.id }}"
      aria-label="Open menu"
    >
      <span class="test-header__burger" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="12" viewBox="0 0 20 12" fill="none">
          <path d="M1 6H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 1H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 11H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="test-header__close" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
          <path d="M1 13.9994L13.7279 1.27147" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M1 1L13.7279 13.7279" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </button>

    <a class="test-header__logo" href="{{ routes.root_url }}">
      {% if block.settings.logo != blank %}
        {{
          block.settings.logo
          | image_url: width: 320
          | image_tag: loading: 'eager', widths: '160, 240, 320', alt: shop.name
        }}
      {% else %}
        <span class="test-header__logo-text">{{ block.settings.logo_text }}</span>
      {% endif %}
    </a>

    <span class="test-header__spacer" aria-hidden="true"></span>

    {% if block.settings.announcement != blank %}
      <p class="test-header__announcement--desktop">
        {{ block.settings.announcement }}
      </p>
    {% endif %}

    {% if block.settings.choose_gift_label != blank %}
      <a
        class="test-header__choose-gift test-header__choose-gift--desktop test-btn test-btn--yellow"
        href="{{ block.settings.choose_gift_link }}"
      >
        <span>{{ block.settings.choose_gift_label }}</span>
        <span class="test-btn__arrow" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="12" viewBox="0 0 26 12" fill="none">
            <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
          </svg>
        </span>
      </a>
    {% endif %}
  </div>

  <div class="test-header__panel" id="test-header-panel-{{ block.id }}" data-test-header-panel>
    {% if block.settings.announcement != blank %}
      <p class="test-header__panel-text">{{ block.settings.announcement }}</p>
    {% endif %}

    {% if block.settings.choose_gift_label != blank %}
      <a
        class="test-header__choose-gift test-header__choose-gift--mobile test-btn test-btn--yellow"
        href="{{ block.settings.choose_gift_link }}"
      >
        <span>{{ block.settings.choose_gift_label }}</span>
        <span class="test-btn__arrow" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="12" viewBox="0 0 26 12" fill="none">
            <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
          </svg>
        </span>
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Hero header",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
    },
    {
      "type": "text",
      "id": "announcement",
      "label": "Announcement text",
    },
    {
      "type": "text",
      "id": "choose_gift_label",
      "label": "Choose gift button label",
    },
    {
      "type": "url",
      "id": "choose_gift_link",
      "label": "Choose gift button link"
    }
  ],
  "presets": [
    {
      "name": "Hero header"
    }
  ]
}
{% endschema %}
