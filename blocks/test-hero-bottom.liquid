{% if block.settings.strip_text != blank %}
  <div class="test-hero__strip test-hero__strip--desktop" {{ block.shopify_attributes }}>
    <p>{{ block.settings.strip_text }}</p>
  </div>
{% endif %}

{% assign strip_mobile = block.settings.strip_text_mobile | default: block.settings.strip_text %}

{% if strip_mobile != blank %}
  <div class="test-hero__strip test-hero__strip--mobile" {{ block.shopify_attributes }}>
    <p>{{ strip_mobile }}</p>
  </div>
{% endif %}

{% schema %}
{
  "name": "Hero bottom",
  "settings": [
    {
      "type": "text",
      "id": "strip_text",
      "label": "Strip text (desktop)",
    },
    {
      "type": "text",
      "id": "strip_text_mobile",
      "label": "Strip text (mobile)",
    }
  ],
  "presets": [
    {
      "name": "Hero bottom"
    }
  ]
}
{% endschema %}
