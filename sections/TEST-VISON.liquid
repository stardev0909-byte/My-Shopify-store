{{ 'TEST.css' | asset_url | stylesheet_tag }}
<script src="{{ 'TEST.js' | asset_url }}" defer></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&family=Lustria&display=swap" rel="stylesheet">

<test-vison-grid
  class="test-vison"
  id="test-vison-{{ section.id }}"
    data-money-format="{{amount_with_comma_separator}}€"
>
  {% if section.settings.heading != blank %}
    <h2 class="test-vison__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="test-vison__items">
    {% content_for 'blocks' %}
  </div>

  <div class="test-popup-overlay" data-test-popup-overlay hidden>
    <div class="test-popup" data-test-popup role="dialog" aria-modal="true" aria-label="Product quick view">
      <button type="button" class="test-popup__close" data-test-close aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
          <path d="M4.24219 4.24285L12.7275 12.7281" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
          <path d="M4.24219 12.7277L12.7275 4.24243" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="test-popup__top">
        <div class="test-popup__image-wrap">
          <img data-test-popup-image src="" alt="" width="" height="">
        </div>
        <div class="test-popup__info">
          <h3 class="test-popup__title" data-test-popup-title></h3>
          <p class="test-popup__price" data-test-popup-price></p>
          <p class="test-popup__description" data-test-popup-description></p>
        </div>
      </div>

      <div class="test-popup__options" data-test-popup-options></div>

      <button type="button" class="test-popup__add test-btn test-btn--black" data-test-add-to-cart>
        <span data-test-add-label>ADD TO CART</span>
        <span class="test-btn__arrow" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="26" height="12" viewBox="0 0 26 12" fill="none">
            <path d="M0.75 4.77298L7.37629e-08 4.77298L-7.37629e-08 6.27298L0.75 6.27298L0.75 4.77298ZM25.2803 6.05331C25.5732 5.76042 25.5732 5.28554 25.2803 4.99265L20.5074 0.21968C20.2145 -0.073213 19.7396 -0.0732131 19.4467 0.21968C19.1538 0.512574 19.1538 0.987447 19.4467 1.28034L23.6893 5.52298L19.4467 9.76562C19.1538 10.0585 19.1538 10.5334 19.4467 10.8263C19.7396 11.1192 20.2145 11.1192 20.5074 10.8263L25.2803 6.05331ZM0.75 6.27298L24.75 6.27298L24.75 4.77298L0.75 4.77298L0.75 6.27298Z" fill="currentColor"/>
          </svg>
        </span>
      </button>
      <p class="test-popup__status" data-test-popup-status></p>
    </div>
  </div>
</test-vison-grid>

{% schema %}
{
  "name": "TEST Vison",
  "tag": "section",
  "class": "test-vison-section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "test-product"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "presets": [
    {
      "name": "TEST Vison",
    }
  ]
}
{% endschema %}
